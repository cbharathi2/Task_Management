# PostgreSQL Database Configuration
# Option 1: Use full connection string (RECOMMENDED for production)
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require

# Option 2: Individual connection params (for local dev)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=task_management

# Database SSL (set to true for external/cloud databases)
DB_SSL=false

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_secret_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Origins (comma-separated, add frontend URLs in production)
# Example: CORS_ORIGINS=https://frontend.vercel.app,https://app.example.com
CORS_ORIGINS=
